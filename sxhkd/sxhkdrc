#App Launch
super + Return
	gnome-terminal

super + space
	rofi -show drun -matching prefix -drun-match-fields name -theme ~/.config/rofi/nord.rasi

super + b 
	firefox --new-window about:blank
#	chromium-browser --app=file:///home/fmireles3/Starthome/index.html --new-window

super + f
	nautilus

super + s 
	gnome-control-center

super + shift + l
	bspc quit

super + shift + i
	pkill -USR1 -x sxhkd && bspc wm -r

# close window
super + q
	bspc node -c

# focus or send to the given desktop
super + {_,shift + }{1-3,0}
	bspc {desktop -f,node -d} '^{1-3,10}'

# Shutdown/Reboot
super + shift + r
	systemctl reboot
	
super + shift + s
	systemctl poweroff

# move window focus
super + Tab
	bspc node -f next.window.local

